# PonsWarp Grid coordinator production/private-beta environment template.
# Copy to a server-only EnvironmentFile; never commit real secrets.

PONSWARP_MESH_ENABLED=true
PONSWARP_MESH_PUBLIC_BASE_URL=https://grid.ponslink.com
PONSWARP_MESH_LEGACY_BASE_URL=https://warp.ponslink.com
PONSWARP_MESH_DATABASE_URL=postgres://ponswarp_grid_app:REPLACE_ME@127.0.0.1:5432/ponswarp_grid_prod?options=-csearch_path%3Dgrid,public
PONSWARP_MESH_DB_SCHEMA=grid
PONSWARP_MESH_RATE_LIMIT_BACKEND=postgres
PONSWARP_MESH_REQUIRE_NODE_TOKEN=true
PONSWARP_MESH_AUDIT_ENABLED=true
PONSWARP_MESH_METRICS_ENABLED=true
PONSWARP_MESH_ADMIN_API_TOKEN=REPLACE_WITH_SECRET
PONSWARP_NODE_TOKEN_PEPPER=REPLACE_WITH_SECRET
PONSWARP_TURN_STATIC_AUTH_SECRET=REPLACE_WITH_SECRET
PONSWARP_TURN_ICE_ENDPOINT=https://grid.ponslink.com/api/grid/v1/ice
PONSWARP_WEB_SHOW_QA_CONTROLS=false
PONSWARP_BUILD_SHA=REPLACE_WITH_GIT_SHA
