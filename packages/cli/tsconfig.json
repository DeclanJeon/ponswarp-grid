{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "paths": {
      "@ponswarp/core": ["../core/src/index.ts"],
      "@ponswarp/signaling": ["../signaling/src/index.ts"],
      "@ponswarp/signaling/server": ["../signaling/src/server.ts"]
    }
  },
  "references": [{ "path": "../core" }, { "path": "../signaling" }],
  "include": ["src/**/*.ts"]
}
